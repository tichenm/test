{
  "name": "guided-pain-discovery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "doctor": "python3 scripts/doctor.py",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:python": "python3 -m unittest discover -s scripts -p '*_test.py'",
    "db:init": "LC_ALL=C /opt/homebrew/opt/postgresql@16/bin/initdb -D .postgres-data -U postgres --auth=trust",
    "db:start": "/opt/homebrew/opt/postgresql@16/bin/pg_ctl -D .postgres-data -l .postgres.log start",
    "db:stop": "/opt/homebrew/opt/postgresql@16/bin/pg_ctl -D .postgres-data stop",
    "db:createdb": "/opt/homebrew/opt/postgresql@16/bin/createdb -h localhost -p 5432 -U postgres guided_pain_discovery",
    "setup:local": "python3 scripts/setup_local.py",
    "smoke:local": "python3 scripts/smoke_local_flow.py",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
